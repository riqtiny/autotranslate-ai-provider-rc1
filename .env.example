# Where converted CTranslate2 models are stored
CT2_MODELS_DIR=./ct2_models

# Inference device: cuda | cpu | auto
CT2_DEVICE=cuda

# Default quantization for conversion/loading: int8_float16 | float16 | int8 | float32
CT2_COMPUTE_TYPE=int8_float16

# Model loaded automatically on startup (registry key). Leave empty to load none.
CT2_DEFAULT_MODEL=qwen3-4b

# Auto-load a model when a request asks for one that isn't loaded
CT2_AUTOSWITCH=true

# API server
CT2_HOST=0.0.0.0
CT2_PORT=8000

# Optional API key. If set, clients must send: Authorization: Bearer <key>
CT2_API_KEY=

# HuggingFace token for gated models (gemma, etc.)
HF_TOKEN=
